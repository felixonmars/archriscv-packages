--- PKGBUILD
+++ PKGBUILD
@@ -6,15 +6,10 @@
   'bootconfig'
   'bpf'
   'cpupower'
-  'hyperv'
-  'intel-speed-select'
-  'kcpuid'
   'linux-tools-meta'
   'perf'
   'tmon'
-  'turbostat'
   'usbip'
-  'x86_energy_perf_policy'
 )
 pkgver=7.0.1
 pkgrel=1
@@ -97,6 +92,7 @@
     PYTHON_CONFIG=python-config \
     LIBPFM4=1 \
     DESTDIR="$pkgdir" \
+    SRCARCH=riscv \
     CLANG=/usr/lib/llvm21/bin/clang
   popd
 
@@ -105,10 +101,6 @@
   make VERSION=$pkgver-$pkgrel
   popd
 
-  echo ':: x86_energy_perf_policy'
-  pushd "$_srcname"/tools/power/x86/x86_energy_perf_policy
-  make
-  popd
 
   echo ':: usbip'
   pushd "$_srcname"/tools/usb/usbip
@@ -124,22 +116,14 @@
   make
   popd
 
-  echo ':: turbostat'
-  pushd "$_srcname"/tools/power/x86/turbostat
-  make
-  popd
 
-  echo ':: hv'
-  pushd "$_srcname"/tools/hv
-  CFLAGS+=' -DKVP_SCRIPTS_PATH=\"/usr/lib/hypervkvpd/\"' make
-  popd
 
   echo ':: bpf'
   pushd "$_srcname"/tools/bpf
   # doesn't compile when we don't first compile bpftool in its own directory and
   # man pages require to be also launch from the subdirectory
   # -j1 added to check for potential repro issues
-  make -j1 -C bpftool all doc
+  make -j1 -C bpftool all doc SRCARCH=riscv
   # runqslower, require kernel binary path to build, skip it
   make -W runqslower
   popd
@@ -149,15 +133,7 @@
   make
   popd
 
-  echo ':: intel-speed-select'
-  pushd "$_srcname"/tools/power/x86/intel-speed-select
-  make
-  popd
 
-  echo ':: kcpuid'
-  pushd "$_srcname"/tools/arch/x86/kcpuid
-  make
-  popd
 }
 
 package_linux-tools-meta() {
@@ -166,14 +142,9 @@
   depends=(
     'bootconfig'
     'bpf'
     'cpupower'
-    'hyperv'
-    'intel-speed-select'
-    'kcpuid'
     'perf'
     'tmon'
-    'turbostat'
     'usbip'
-    'x86_energy_perf_policy'
   )
   conflicts=(
     'acpidump'
@@ -200,6 +171,7 @@
     PYTHON_CONFIG=python-config \
     DESTDIR="$pkgdir" \
     LIBPFM4=1 \
+    SRCARCH=riscv \
     install install-python_ext
   cd "$pkgdir"
   # add linker search path
