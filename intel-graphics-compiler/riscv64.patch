@@ -72,6 +75,20 @@
     export CFLAGS="${CFLAGS/-Wp,-D_FORTIFY_SOURCE=?/}"
     export CXXFLAGS="${CXXFLAGS/-Wp,-D_FORTIFY_SOURCE=?/}"
 
+    # fix error: 'cdecl' attribute directive ignored [-Werror=attributes]
+    # note: https://github.com/intel/intel-graphics-compiler/pull/370
+    export CFLAGS+=' -Wno-error=attributes'
+    export CXXFLAGS+=' -Wno-error=attributes'
+
+    # fix error: 'void operator delete(void*, std::size_t)' called on pointer '<unknown>' with nonzero offset 40 [-Werror]
+    # note: False positive? in STL
+    export CFLAGS+=' -Wno-error=free-nonheap-object'
+    export CXXFLAGS+=' -Wno-error=free-nonheap-object'
+
+    # fix error: #warning "<ciso646> is deprecated in C++17 [-Werror]
+    export CFLAGS+=' -Wno-error=cpp'
+    export CXXFLAGS+=' -Wno-error=cpp'
+
     export GIT_COMMITTER_NAME='builduser'
     export GIT_COMMITTER_EMAIL='builduser@archlinux.org'
     
