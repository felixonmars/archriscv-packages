+cxx = "x86_64-linux-gnu-g++"
+ar = "x86_64-linux-gnu-gcc-ar"
+ranlib = "x86_64-linux-gnu-ranlib"
+linker = "x86_64-linux-gnu-gcc"
+default-linker = "x86_64-linux-gnu-gcc"
+sanitizers = false
+
 [target.wasm32-unknown-unknown]
 cc = "clang"
 cxx = "clang++"
